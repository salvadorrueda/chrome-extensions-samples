{
  "name": "Input Fields Analyzer",
  "description": "Highlights and analyzes text boxes and interactive input elements on any web page.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "128": "icons/128.png"
  },
  "permissions": ["activeTab", "scripting"]
}
