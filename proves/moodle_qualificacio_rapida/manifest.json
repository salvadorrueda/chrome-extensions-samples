{
  "manifest_version": 3,
  "name": "Analitzador d'Elements Clicables",
  "version": "1.0",
  "description": "Analitza una web i fa un llistat de tots els elements on es pot fer clic",
  "permissions": ["activeTab", "scripting"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analitzador d'Elements Clicables",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
